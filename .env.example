# Скопируйте: cp .env.example .env
# Локально — значения ниже уже подходят к docker-compose.dev.yml
# На VPS — смените POSTGRES_PASSWORD и SECRETS_ENCRYPTION_KEY (или используйте install.sh)

ENVIRONMENT=development

# ── PostgreSQL ──────────────────────────────────────────────
# Локально (docker-compose.dev.yml): логин/пароль/БД = lztbuilder
POSTGRES_USER=lztbuilder
POSTGRES_PASSWORD=lztbuilder
POSTGRES_DB=lztbuilder

# URL для локального запуска api/worker на хосте (не в compose)
DATABASE_URL=postgresql+asyncpg://lztbuilder:lztbuilder@localhost:5432/lztbuilder
DATABASE_URL_SYNC=postgresql+psycopg2://lztbuilder:lztbuilder@localhost:5432/lztbuilder

# ── Redis / Celery ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Шифрование токенов LZT в БД ─────────────────────────────
# Пусто = plaintext (только локально). На VPS обязательно:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# ── URL ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
WEBHOOK_BASE_URL=http://localhost:8000
# Пусто на VPS = same-origin через nginx
NEXT_PUBLIC_API_URL=

# ── Порты (только docker compose prod / install.sh) ─────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Лимиты на инстанс ───────────────────────────────────────
MAX_ACTIVE_FLOWS_PER_USER=50
MAX_RUNS_PER_HOUR=120
MAX_CONCURRENT_RUNS_PER_USER=3
MAX_FLOW_FILE_BYTES=5000000

# ── VPS: перед запуском смените минимум ─────────────────────
# ENVIRONMENT=production
# POSTGRES_PASSWORD=<только буквы/цифры, openssl rand -hex 24>
# SECRETS_ENCRYPTION_KEY=<fernet>
# CORS_ORIGINS=https://YOUR_DOMAIN   или  http://IP:3001
# WEBHOOK_BASE_URL=...то же...
# HTTP_PORT=3001
